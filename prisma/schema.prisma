generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(cuid())
  name           String
  email          String        @unique
  password       String?
  initials       String
  role           String        @default("developer")
  avatarColor    String        @default("#667eea")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  issues         Issue[]
  comments       Comment[]
  timeLogs       TimeLog[]
  messages       ChatMessage[]
  assignedIssues Issue[]       @relation("AssignedTo")
  history        IssueHistory[]
}

model Sprint {
  id        String   @id @default(cuid())
  name      String
  goal      String
  startDate DateTime
  endDate   DateTime
  status    String   @default("active")
  issues    Issue[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Issue {
  id        String  @id @default(cuid())
  key       String  @unique
  title     String
  description String @default("")
  type      String  @default("task")
  priority  String  @default("medium")
  status    String  @default("todo")
  estimate  Int     @default(0)
  sprint    Sprint? @relation(fields: [sprintId], references: [id])
  sprintId  String?
  reporter  User    @relation(fields: [reporterId], references: [id])
  reporterId String
  assignee  User?   @relation("AssignedTo", fields: [assigneeId], references: [id])
  assigneeId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  comments  Comment[]
  timeLogs  TimeLog[]
  history   IssueHistory[]
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  issue     Issue    @relation(fields: [issueId], references: [id])
  issueId   String
  createdAt DateTime @default(now())
}

model TimeLog {
  id        String   @id @default(cuid())
  hours     Float
  date      DateTime
  note      String   @default("")
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  issue     Issue    @relation(fields: [issueId], references: [id])
  issueId   String
  createdAt DateTime @default(now())
}

model IssueHistory {
  id        String   @id @default(cuid())
  action    String
  fromValue String   @default("")
  toValue   String   @default("")
  issue     Issue    @relation(fields: [issueId], references: [id])
  issueId   String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  body      String
  isAI      Boolean  @default(false)
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  createdAt DateTime @default(now())
}

model Automation {
  id          String   @id @default(cuid())
  name        String
  description String
  trigger     String
  action      String
  enabled     Boolean  @default(true)
  icon        String   @default("zap")
  color       String   @default("#667eea")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Initiative {
  id        String   @id @default(cuid())
  name      String
  progress  Int      @default(0)
  items     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
